# Binaries
/bin/
*.exe
*.dll
*.so
*.dylib

# Build artifacts in the repo root — `go build .` inside each cmd/*
# leaves the binary here. cmd/ subdirs are name-matched.
/fc-dev
/fc-server
/fc-router
/fc-platform-server
/fc-stream-processor
/fc-outbox-processor
/fc-mcp-server
/parityharness
/dump-spec

# Test artifacts
*.test
*.out
coverage.txt
coverage.html

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build
/build/
/dist/

# Local env
.env
.env.local
*.local

# Per-user Claude Code settings (the .json suffix means *.local doesn't catch it)
.claude/settings.local.json

# Air (hot reload)
tmp/

# Migrated client SDK build artifacts (clients/laravel-sdk has its own
# .gitignore for vendor/ + composer.lock; the TS SDK ships none).
clients/typescript-sdk/node_modules/
clients/typescript-sdk/dist/
clients/typescript-sdk/*.tsbuildinfo

# Frontend build artefacts (regenerated by `make frontend` / pnpm build)
frontend/dist/
frontend/node_modules/
frontend/.vite/
frontend/*.tsbuildinfo
# Note: frontend/src/api/generated/ is intentionally NOT ignored. It's
# the Hey-API-generated TS client checked in alongside the Rust spec;
# until Go's OpenAPI emitter lands we treat the generated dir as the
# source of truth (matches what the Rust repo does today).
